# Copy to .env and fill in real values. Never commit .env.

# Django
SECRET_KEY=replace-me-with-a-strong-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (Render supplies DATABASE_URL automatically in prod)
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/afya_mkononi_dev

# AI provider
AI_PROVIDER=claude
AI_API_KEY=your-anthropic-api-key

# Human support / care team
# The WhatsApp number shown on the dashboard is managed in Django Admin
# (Core > Site settings), NOT here. Seed it there after first migrate, e.g.
# 254712345678 (international format, digits only, no '+').

# Email (password-reset links). Dev default prints emails to the runserver
# console, so you can leave these unset locally.
#
# Production note: Render (and most PaaS hosts) BLOCK outbound SMTP ports, so
# raw SMTP to Gmail will hang. Send via Brevo's HTTPS API instead, using these:
# EMAIL_BACKEND=anymail.backends.brevo.EmailBackend
# BREVO_API_KEY=your-brevo-api-key
# DEFAULT_FROM_EMAIL=Afya Mkononi <your-verified-sender@example.com>
